# Dogtap external-injection defaults for an app that already uses Datadog.
#
# Containers in the same Docker Compose project should use dogtap.
# Host processes should use localhost.
#
# Prefer DD_TRACE_AGENT_URL where supported because it overrides host/port
# ambiguity in many tracers.
DD_TRACE_AGENT_URL=http://dogtap:8126
DD_AGENT_HOST=dogtap
DD_TRACE_AGENT_PORT=8126

# Keep normal unified service tags. Replace these values per service.
DD_ENV=local
DD_SERVICE=your-backend
DD_VERSION=local

# Preserve Datadog trace/log correlation behavior. This does not send logs by
# itself; it injects trace IDs into supported log frameworks.
DD_LOGS_INJECTION=true
DD_TRACE_SAMPLE_RATE=1

# Optional OTLP path for services that already emit OpenTelemetry logs,
# traces, or metrics.
OTEL_SERVICE_NAME=your-backend
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local,service.version=local
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=http://dogtap:4318
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://dogtap:4318/v1/traces
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://dogtap:4318/v1/logs
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://dogtap:4318/v1/metrics
OTEL_TRACES_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp

# Frontend apps should expose this through runtime config and pass it to
# datadogRum.init({ proxy }).
DATADOG_RUM_PROXY_URL=http://localhost:8080/datadog-intake-proxy

# Not supported by Dogtap yet:
# - DogStatsD on UDP 8125
# - Datadog Agent container stdout/file log tailing
# - Datadog Agent integrations and Autodiscovery checks
