# Backend containers in the same Docker Compose project should use dogtap.
# Host processes should use http://localhost:4317 instead.
OTEL_SERVICE_NAME=your-backend
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local,service.version=local
OTEL_TRACES_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_ENDPOINT=http://dogtap:4317
